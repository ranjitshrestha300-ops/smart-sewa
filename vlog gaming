<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Vlog & Gaming Hub - Smart Sewa</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="style.css">
    <style>
        .youtube-video-container { position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden; border-radius: 6px; background: #000; margin-bottom: 15px; }
        .youtube-video-container iframe { position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: 0; }
        .btn-youtube-sub { background: #ff0000; color: #fff; display: flex; align-items: center; justify-content: center; gap: 8px; padding: 12px; border-radius: 6px; text-decoration: none; font-weight: bold; }
        .media-hub-grid { display: grid; grid-template-columns: 2fr 1fr; gap: 25px; margin-top: 30px; }
        @media (max-width: 768px) { .media-hub-grid { grid-template-columns: 1fr; } }
    </style>
</head>
<body>
    <div id="fb-root"></div>
    <script async defer crossorigin="anonymous" src="https://connect.facebook.net/en_US/sdk.js#xfbml=1&version=v17.0"></script>

    <header>
        <div class="nav-wrapper">
            <a href="index.html" class="brand-master-logo"><div class="brand-typography-block"><div class="brand-main-title">Smart<span>Sewa</span></div></div></a>
            <a href="index.html" class="cta-nav-btn">Back to Home</a>
        </div>
    </header>

    <div class="main-wrapper">
        <div class="media-hub-grid">
            <div style="background:#fff; padding:20px; border-radius:8px; border:1px solid #e2e8f0;">
                <h3><i class="fa-brands fa-youtube" style="color: red;"></i> Nepal Taxi Vlog</h3>
                <div class="youtube-video-container">
                    <iframe src="https://www.youtube.com/embed/videoseries?list=UU_K9OWslefMfCpOqLHCLfTA" allowfullscreen></iframe>
                </div>
                <a href="https://www.youtube.com/channel/UC_K9OWslefMfCpOqLHCLfTA?sub_confirmation=1" class="btn-youtube-sub" target="_blank">Subscribe Channel</a>
            </div>
            
            <div style="background:#fff; padding:20px; border-radius:8px; border:1px solid #e2e8f0; display:flex; flex-direction:column; align-items:center;">
                <h3><i class="fa-brands fa-facebook" style="color: #1877f2;"></i> Facebook Feed</h3>
                <div class="fb-page" data-href="https://www.facebook.com/share/1F2nALbbdv/" data-tabs="timeline" data-width="340" data-height="400" data-small-header="false" data-adapt-container-width="true"></div>
            </div>
        </div>
    </div>
    <footer><p>© 2026 Smart Sewa Nepal.</p></footer>
</body>
</html>
